# LLM Configuration
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-3.5-turbo
# LLM_API_BASE=https://api.openai.com/v1  # Optional: for custom API endpoints
# LLM_TEMPERATURE=0.7  # Optional: reasoning temperature

# Browser Configuration
# BROWSER_HEADLESS=false  # false = visible browser (default), true = headless
# BROWSER_TIMEOUT=30000  # ms
# PAGE_WAIT_TIMEOUT=10000  # ms

# Automation Configuration
# FIELD_FILL_DELAY_MIN=500  # ms
# FIELD_FILL_DELAY_MAX=1500  # ms
# VALIDATION_RETRY_MAX=2  # retry attempts for validation errors
# CHECKPOINT_INTERVAL=3  # save checkpoint every N fields

# Session Configuration
# SESSION_EXPIRY_HOURS=24

# File Paths
# PROFILE_FILE=profile.json
# SESSION_FILE=.session.json
# CHECKPOINT_FILE=.checkpoint.json
# LOG_FILE=application.log
